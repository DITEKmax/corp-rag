# The canonical environment reference is ../.env.example.
# From this directory, run:
# docker compose --env-file ../.env.example -f docker-compose.yml up -d --build
#
# infra/docker-compose.yml also supplies safe local defaults for every variable
# so config rendering works even when this pointer file is used as the env file.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL_ID=deepseek/deepseek-v4-flash

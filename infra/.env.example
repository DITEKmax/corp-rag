# The canonical environment reference is ../.env.example.
# From this directory, run:
# docker compose --env-file ../.env.example -f docker-compose.yml up -d --build
#
# infra/docker-compose.yml also supplies safe local defaults for every variable
# so config rendering works even when this pointer file is used as the env file.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEEPSEEK_MODEL_ID=deepseek/deepseek-v4-flash:free  (default; override only for paid tier)

AI_QUERY_TIMEOUT_SECONDS=30
AI_ROUTER_CONFIDENCE_THRESHOLD=0.65
AI_RERANKER_ENABLED=true
AI_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
AI_RERANKER_TIMEOUT_SECONDS=25
AI_RERANKER_LOAD_TIMEOUT_SECONDS=28
AI_QUERY_PREWARM_ENABLED=true
AI_QUERY_PREWARM_TIMEOUT_SECONDS=45
PYTHON_AI_MEMORY_LIMIT=8g
PYTHON_AI_MEMORY_RESERVATION=6g
AI_CONTEXT_TOKEN_CAP=4000
AI_WEAK_EVIDENCE_THRESHOLD=0.4
AI_FLAGGED_CHUNK_SCORE_MULTIPLIER=0.5
